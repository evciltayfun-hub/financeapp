generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Asset {
  id        String   @id @default(cuid())
  symbol    String
  name      String
  type      String   // BIST | US | CRYPTO
  lots      Lot[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([symbol, type])
}

model Lot {
  id           String   @id @default(cuid())
  assetId      String
  asset        Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  quantity     Float
  costPriceTL  Float?
  costPriceUSD Float?
  purchaseDate DateTime @default(now())
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model MonthlyGoal {
  id                String   @id @default(cuid())
  year              Int
  month             Int
  // Planlanan
  netSalary         Float    @default(0)  // Net Maaş (Hesaba Yatan)
  spendingTarget    Float    @default(0)  // Harcama (Hedef)
  besInvestment     Float    @default(0)  // BES Yatırımı (Kişisel)
  investmentTarget  Float    @default(0)  // Yatırıma Kalan (Nakit) = netSalary - spendingTarget - besInvestment
  // Gerçekler
  actualInvestment  Float    @default(0)  // Yapılan Yatırım
  remainingCash     Float    @default(0)  // Kalan Nakit
  creditCardTL      Float    @default(0)  // Kredi Kartı Borcu TL
  creditCardEUR     Float    @default(0)  // Kredi Kartı Borcu EUR
  netAmount         Float    @default(0)  // NET
  note              String?              // Notlar
  isChecked         Boolean  @default(false)
  extraAmount       Float    @default(0)  // Ekstra
  isExtraChecked    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([year, month])
}

model CashBalance {
  id        String   @id @default(cuid())
  currency  String   @unique  // TRY, USD, EUR
  amount    Float    @default(0)
  label     String   @default("")
  updatedAt DateTime @updatedAt
}

model PortfolioNote {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WatchlistItem {
  id        String   @id @default(cuid())
  symbol    String
  type      String   // BIST | US | CRYPTO
  name      String
  createdAt DateTime @default(now())

  @@unique([symbol, type])
}

model Subscription {
  id              String   @id @default(cuid())
  name            String
  category        String
  price           Float
  currency        String   @default("₺")
  period          String   // "monthly" | "yearly"
  paymentMonth    Int?     // 1-12, only for yearly
  isActive        Boolean  @default(true)
  activatedFrom   Int?     // yyyymm — month from which active (null = always)
  deactivatedFrom Int?     // yyyymm — month from which inactive (null = always inactive if !isActive)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MonthlyBudget {
  id            String   @id @default(cuid())
  year          Int
  month         Int      // 1-12
  carryover     Float    @default(0)  // Önceki aydan devir
  salary        Float    @default(0)
  extraIncome   Float    @default(0)  // Ek gelir
  otherExpenses Float    @default(0)
  investment    Float    @default(0)  // Yatırıma aktarılacak
  note          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([year, month])
}
